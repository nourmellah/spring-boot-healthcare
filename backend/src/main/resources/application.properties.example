# ============================================================
# Copy this file to application.properties and fill in values
# NEVER commit application.properties to git
# ============================================================

# Application
spring.application.name=healthcare-management-system
server.port=8080

# Database
spring.datasource.url=jdbc:mysql://localhost:3306/healthcare_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect

# Logging
logging.level.org.springframework.security=WARN
logging.level.com.healthcare=INFO

# File Upload
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# JWT - Use a strong random secret (min 64 chars)
jwt.secret=CHANGE_THIS_TO_A_STRONG_RANDOM_SECRET_MIN_64_CHARACTERS
jwt.expiration=86400000

# Bootstrap Admin - Change before first run
bootstrap.admin.email=admin@yourhospital.com
bootstrap.admin.password=CHANGE_THIS_STRONG_PASSWORD
bootstrap.admin.firstName=System
bootstrap.admin.lastName=Administrator
bootstrap.admin.phone=0000000000
